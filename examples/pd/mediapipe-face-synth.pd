#X obj 50 170 else/osc.route /mouth;
#X obj 50 210 else/osc.route /lower;
#X obj 50 250 else/osc.route /y;
#X obj 50 290 else/smooth 50;
#X obj 50 330 cyclone/scale 0.45 0.65 200 4000;
