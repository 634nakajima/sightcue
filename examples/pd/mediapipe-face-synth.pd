#X obj 300 170 else/osc.route /nose;
#X obj 300 210 else/osc.route /tip;
#X obj 300 250 else/osc.route /x;
#X obj 300 290 else/smooth 50;
#X obj 300 330 cyclone/scale 0.2 0.8 150 600;
#X text 435 335 nose x -> pitch;
#X obj 550 170 else/osc.route /left_eyebrow;
