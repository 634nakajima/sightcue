#X obj 550 250 else/osc.route /y;
#X obj 550 290 else/smooth 50;
#X obj 550 330 cyclone/scale 0.35 0.15 0 0.5;
#X text 700 335 eyebrow -> volume;
#X obj 300 400 osc~;
#X obj 50 440 vcf~ 0 8;
#X obj 50 490 *~;
#X obj 50 550 else/out~ 1;
